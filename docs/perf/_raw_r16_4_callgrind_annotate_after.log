# claim_with_config calls memset 4 TIMES (per heap materialisation) — same 4 call
# sites as "before", byte-identical Rust source, only two of the four grew:
#   1. edx=0x400  (1024 B), esi=0xff — UNCHANGED (0x400 in both builds; unrelated to
#      MAX_SEGMENTS)
#   2. edx=0x10000 (65,536 B), esi=0 — HASH_CAPACITY*8 = 2*4096*8 = 65,536 B exactly
#      (registry hash-table zero-fill, bootstrap.rs "4b. OPT-B" loop; was 16,384 B)
#   3. edx=0x4004 (16,388 B), esi=0  — FREE_LIST_CAPACITY*4 + 4 = 4096*4+4 = 16,388 B
#      exactly (free-list index-stack zero-fill, bootstrap.rs "4c" loop; was 4,100 B)
#   4. (byte-identical to "before")
# Disassembly (objdump -d --demangle) of the two MAX_SEGMENTS-scaled calls, AFTER:
#   4380b: mov 0x4453e(%rip),%r14   # 87d50 <memset@GLIBC_2.2.5>
#   43812: mov $0x400,%edx  ; 43817: mov $0xff,%esi ; 4381c: call *%r14   [[UNRELATED, 1024B]]
#   43853: lea 0x1a000(%r13),%rdi
#   4385a: mov $0x10000,%edx ; 4385f: xor %esi,%esi  ; 43861: call *%r14  [[HASH_CAPACITY*8 = 65536B]]
#   43878: lea 0x2a000(%r13),%rdi
#   4387f: mov $0x4004,%edx  ; 43884: xor %esi,%esi  ; 43886: call *%r14  [[FREE_LIST_CAPACITY*4+4 = 16388B]]
#
# --------------------------------------------------------------------------
# Byte-delta reconciliation against the reported +61,440 Ir flat delta
# --------------------------------------------------------------------------
#   hash-table zero-fill:      65,536 - 16,384 =  49,152 bytes
#   free-list zero-fill:       16,388 -  4,100 =  12,288 bytes
#   sum of the two deltas:                        61,440 bytes
#   observed Ir delta (before -> after, small_churn_16b):  90,017 - 28,576 = 61,441 Ir
#   -> matches to within 1 Ir (61,440 bytes vs 61,441 Ir; the 1-Ir residual is call-site
#      register-immediate encoding noise, not a second mechanism). __memset_avx2_unaligned_erms's
#      Ir cost for THIS byte range is empirically ~1 retired instruction per extra byte zeroed.
